# URL where the FastAPI server is running
BASE_URL="http://localhost:8000/"

# OpenAPI spec URL (used by the MCP server to auto-generate tools)
BASE_URL_DOCS="http://localhost:8000/openapi.json"

# MCP server URL (used by the CLI to list and call tools)
MCP_URL="http://localhost:8001/mcp"

# Your LiteLLM proxy master key
OPENAI_KEY="sk-your-litellm-master-key"

# Your LiteLLM proxy URL (local or deployed)
LITELLM_URL="http://localhost:4000"
